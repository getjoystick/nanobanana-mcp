{
  "name": "@nanobanana/mcp",
  "version": "0.2.0",
  "mcpName": "io.github.getjoystick/nanobanana-mcp",
  "description": "Lean MCP server for Google's Nano Banana (Gemini) image models. Generates and edits images, returns file paths.",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "nanobanana-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "smoke": "node scripts/smoke.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "nano-banana",
    "gemini",
    "image-generation",
    "image-editing",
    "claude",
    "cursor"
  ],
  "author": "Joystick Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getjoystick/nanobanana-mcp.git"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  }
}
