# Required. Get one at https://aistudio.google.com/apikey (GOOGLE_API_KEY also accepted)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: default image model (also overridable per tool call via `model`)
# Options: gemini-3.1-flash-image (default), gemini-3-pro-image, gemini-2.5-flash-image
# NANOBANANA_MODEL=gemini-3.1-flash-image

# Optional: default save directory (also overridable per tool call via `outputDir`)
# NANOBANANA_OUTPUT_DIR=~/Pictures/nano-banana
